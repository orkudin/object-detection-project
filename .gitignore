# ============================================================
# .gitignore — UAV-CV-Navigator
# ============================================================

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/

# ── Виртуальные окружения ────────────────────────────────────
.env
.venv
env/
venv/
conda-env/

# ── Модели и веса (тяжёлые бинарные файлы) ──────────────────
# Все веса хранятся в models/ и НЕ коммитятся.
# Для воспроизводимости: скачайте их скриптом или экспортируйте.
models/*.pt
models/*.pth
models/*.onnx
models/*.rknn
models/*.engine
models/*.tflite

# Устаревшие веса в корне (на случай если забыли перенести)
*.pt
*.pth
*.onnx
*.rknn
*.engine
*.tflite

# ── Ultralytics / W&B артефакты ──────────────────────────────
runs/
wandb/

# ── Данные ───────────────────────────────────────────────────
# Игнорируем всё в data/, кроме скриптов загрузки и README
data/*
!data/download_test_video.py
!data/README.md

# ── Выходные файлы пайплайна ─────────────────────────────────
data/output/

# ── Логи и телеметрия ────────────────────────────────────────
*.log
*.jsonl

# ── IDE и редакторы ──────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Jupyter / Colab ──────────────────────────────────────────
.ipynb_checkpoints/

# ── Временные и scratch-файлы ────────────────────────────────
scratch_test.py
tmp/
